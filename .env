# ── AI Configuration ──────────────────────────────
# Set your OpenAI-compatible API key here
OPENAI_API_KEY=your_api_key_here

# Base URL for the AI API (default: OpenAI)
AI_BASE_URL=https://api.openai.com/v1

# Model to use
AI_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────
PORT=5000
